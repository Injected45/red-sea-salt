0:{"rsc":["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/1558xhk3c944s.css","precedence":"next"}],["$","script","script-0",{"src":"/_next/static/chunks/016u~53lvf.df.js","async":true}],["$","script","script-1",{"src":"/_next/static/chunks/0h__3hfiarg7k.js","async":true}]],["$","html",null,{"lang":"ar","dir":"rtl","className":"inter_fd091ad6-module__giF-bG__variable tajawal_5f406910-module__oc84sa__variable playfair_display_7412400-module__yfHGFq__variable","children":["$","body",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"ملح البحر الأحمر\",\"description\":\"شركة ملح البحر الأحمر — إنتاج وتوريد الملح الصناعي، ملح إزالة الجليد، ملح المسابح، الملح المكرر، والملح المغسول من رأس غارب، البحر الأحمر.\",\"url\":\"https://redseasalt.example\",\"address\":{\"@type\":\"PostalAddress\",\"addressLocality\":\"Ras Gharib\",\"addressRegion\":\"Red Sea\",\"addressCountry\":\"EG\"},\"foundingDate\":\"2011\"}"}}],["$","$L2",null,{"locale":"ar","messages":{"meta":{"siteName":"ملح البحر الأحمر","tagline":"مورد موثوق للملح الصناعي منذ 2011","description":"شركة ملح البحر الأحمر — إنتاج وتوريد الملح الصناعي، ملح إزالة الجليد، ملح المسابح، الملح المكرر، والملح المغسول من رأس غارب، البحر الأحمر."},"nav":{"home":"الرئيسية","about":"من نحن","products":"المنتجات","industries":"القطاعات","blog":"المدونة","contact":"تواصل معنا","faq":"الأسئلة الشائعة","requestQuote":"اطلب عرض سعر"},"common":{"learnMore":"اعرف المزيد","viewAll":"عرض الكل","viewDetails":"عرض التفاصيل","contactUs":"تواصل معنا","requestInfo":"اطلب معلومات","since":"منذ","readMore":"اقرأ المزيد","backToProducts":"العودة إلى المنتجات"},"home":{"hero":{"eyebrow":"تأسست عام 2011 · مصر","title":"ملح مصري نقي لأسواق العالم","subtitle":"شركة مصرية لإنتاج الملح الصناعي والغذائي وملح إذابة الجليد وملح سيوة. نشحن من كافة الموانئ المصرية عبر شركائنا الموثوقين.","ctaPrimary":"استعرض المنتجات","ctaSecondary":"تواصل معنا","trustedBy":"نخدم قطاعات متعددة في المنطقة","sectors":{"construction":"الإنشاءات","chemicals":"الكيماويات","food":"الغذاء","pools":"المسابح","export":"التصدير","infrastructure":"البنية التحتية","textiles":"النسيج","logistics":"اللوجستيات"},"locationLabel":"المنشأ","qualityAssured":"جودة مضمونة","since":"منذ","stats":{"years":"سنوات خبرة","products":"منتجات","quality":"نقاء","support":"دعم"}},"about":{"eyebrow":"من نحن","title":"خبرة تزيد عن عقد من الزمن","body":"نعمل منذ عام 2011 في إنتاج الملح الصناعي والغذائي وملح إذابة الجليد وملح سيوة بجودة عالية من مواقع متعددة داخل مصر، ونشحن من كافة الموانئ المصرية الكبرى عبر شركائنا الموثوقين — نخدم قطاعات الصناعة والغذاء والبنية التحتية في المنطقة.","cta":"تعرف علينا","shippingTitle":"شحن من كافة موانئ مصر","shippingBody":"لسنا مقتصرين على البحر الأحمر — شركاؤنا الموثوقون يتولّون الشحن والتصدير من كل ميناء مصري كبير.","badgeLabel":"تأسست 2011","badgeLocation":"مصر"},"categories":{"eyebrow":"منتجاتنا","title":"تشكيلة كاملة من منتجات الملح","subtitle":"نلبي احتياجات جميع القطاعات بمنتجات متعددة وخصائص تقنية مختلفة."},"whyUs":{"eyebrow":"لماذا نحن","title":"لماذا تختار ملح البحر الأحمر","items":{"experience":{"title":"خبرة ممتدة","body":"أكثر من 14 عامًا في إنتاج وتوريد الملح الصناعي."},"capacity":{"title":"طاقة إنتاجية كبيرة","body":"قدرة على تلبية الطلبات الكبيرة والمتكررة بانتظام."},"quality":{"title":"جودة مضمونة","body":"ملح نقي بمواصفات قياسية تلبي احتياجات الصناعة."},"reliability":{"title":"موثوقية وتسليم","body":"التزام بالمواعيد مع مرونة في التعبئة والشحن."}}},"industries":{"eyebrow":"القطاعات التي نخدمها","title":"حلول ملحية لكل قطاع","subtitle":"نوفر منتجات ملائمة للبنية التحتية والصناعة والغذاء والمسابح والتوريد التجاري."},"featured":{"eyebrow":"مميز","title":"منتجات مختارة","subtitle":"اطلع على أبرز منتجاتنا الأكثر طلبًا."},"cta":{"eyebrow":"تواصل معنا","title":"هل تحتاج إلى عرض سعر أو معلومات تقنية؟","body":"فريقنا جاهز للرد على استفساراتك وتوفير المواصفات وخيارات التعبئة والتوريد.","button":"اطلب عرض سعر الآن","secondary":"استعرض المنتجات"},"gallery":{"eyebrow":"عالمنا","title":"رحلة","titleItalic":"بصرية","subtitle":"من أحواض التبخير الغنية بالمعادن في رأس غارب إلى موانئ التصدير التي تحمل منتجنا عبر المنطقة.","captionEyebrow":"لقطة","viewImage":"عرض الصورة","close":"إغلاق","next":"الصورة التالية","prev":"الصورة السابقة","items":{"rawHarvest":"حصاد الملح الخام","marine":"ملح بحري بالتبخير الشمسي","tablets":"أقراص ملح مضغوطة","rockSalt":"ملح صخري خشن جاهز للتصدير","foodGrade":"ملح غذائي مكرر","industrial":"إنتاج بجودة صناعية"}},"testimonials":{"eyebrow":"آراء عملائنا","title":"أصوات من","titleItalic":"الميدان","subtitle":"تجارب حقيقية من المشترين والمقاولين والمشغلين الذين يوردون منا.","emptyTitle":"كن أول من يشارك تجربته","emptyBody":"فور نشر أول مراجعة معتمدة، ستظهر هنا — يمكن أن يكون صوتك هو الأول.","form":{"eyebrow":"شاركنا رأيك","title":"أضف تقييمك","subtitle":"تتم مراجعة التقييمات قبل نشرها.","rating":"تقييمك","selectRating":"اختر تقييمًا","name":"الاسم","email":"البريد الإلكتروني","message":"رأيك","disclaimer":"لن يُنشر بريدك الإلكتروني — نستخدمه للتحقق فقط.","submit":"إرسال التقييم"},"status":{"sending":"جاري الإرسال…","okTitle":"شكرًا على تقييمك","okBody":"تم استلام رأيك وسيتم نشره بعد مراجعة سريعة.","errors":{"missing_fields":"يرجى ملء جميع الحقول المطلوبة.","invalid_email":"يرجى إدخال بريد إلكتروني صحيح.","invalid_rating":"يرجى اختيار تقييم من 1 إلى 5 نجوم.","not_configured":"خدمة التقييمات غير متصلة بقاعدة البيانات بعد. يرجى المحاولة لاحقًا.","db_error":"حدث خطأ غير متوقع. يرجى المحاولة مرة أخرى بعد قليل."}}}},"about":{"hero":{"title":"من نحن","subtitle":"شركة مصرية رائدة في إنتاج وتوريد الملح الصناعي من رأس غارب منذ 2011."},"story":{"title":"قصتنا","body":"انطلقت شركة ملح البحر الأحمر عام 2011 برؤية واضحة: تقديم منتج ملحي عالي الجودة يلبي احتياجات الصناعة والبنية التحتية محليًا ودوليًا. على مدار أكثر من عقد، طورنا خطوط الإنتاج، ووسعنا شبكة التوريد، وبنينا شراكات طويلة الأمد مع كبرى الشركات في المنطقة."},"mission":{"title":"رسالتنا","body":"توفير منتجات ملحية نقية ومتوافقة مع المواصفات الصناعية، بجودة ثابتة وخدمة توريد موثوقة."},"vision":{"title":"رؤيتنا","body":"أن نكون المورد الأول لمنتجات الملح في المنطقة من خلال الجودة والالتزام والابتكار."},"values":{"title":"قيمنا","items":["الجودة","الموثوقية","الالتزام بالمواعيد","الشفافية","خدمة العميل"]},"location":{"title":"موقعنا","body":"رأس غارب، محافظة البحر الأحمر، جمهورية مصر العربية — موقع استراتيجي يسهل الوصول البحري والبري."},"founder":{"eyebrow":"تعرّف على المؤسس","name":"رجب سالم","role":"مؤسس شركة ملح البحر الأحمر","tagline":"خمسة عشر عامًا من التميّز — من قلب مصر إلى الأسواق العالمية.","body":"بوصفي مؤسس شركة «ملح البحر الأحمر» منذ عام 2011، كرّست مسيرتي المهنية لتحويل الثروات الطبيعية في مصر إلى منتجات استراتيجية بمعايير عالمية. وبخبرة تقنية تتجاوز 15 عامًا في التبلور والنقاء الكيميائي، نوفّر الشراكة الأمثل للشركات الباحثة عن ملح مصري متميز. رسالتنا هي ردم الفجوة بين الإنتاج المحلي والمعايير الدولية، لضمان نجاح سلس في الأسواق العالمية.","imageAlt":"رجب سالم، مؤسس شركة ملح البحر الأحمر"}},"products":{"listing":{"title":"منتجاتنا","subtitle":"تشكيلة متكاملة من منتجات الملح الصناعي والغذائي"},"detail":{"specifications":"المواصفات","keyFeatures":"المميزات الرئيسية","applications":"الاستخدامات","packaging":"التعبئة","gallery":"معرض الصور","videoTour":"جولة مصورة","analysis":"التحليل الكيميائي","cta":"اطلب هذا المنتج"},"specsLabels":{"purity":"النقاء","moisture":"الرطوبة","granule":"حجم الحبيبات"},"items":{"raw-salt":{"name":"الملح الخام","short":"بلورات ملح طبيعية شمسية وصخرية للاستخدام الصناعي بكميات كبيرة.","description":"بلورات ملح طبيعية شمسية وصخرية يتم حصادها من ملاحاتنا داخل مصر، وتُصدَّر بكميات كبيرة للاستخدام الصناعي أو كمادة خام للتكرير اللاحق. يحتفظ بمكوناته المعدنية الطبيعية ونسبة من الرطوبة، مما يجعله خيارًا مثاليًا للعمليات الصناعية اللاحقة.","keyFeatures":["مستخرج طبيعيًا من أرض مصر","غني بالمعادن الطبيعية","مادة خام مثالية للتكرير والصناعات الكيميائية","متاح بكميات كبيرة جاهزة للتصدير","توريد منتظم ومستقر طوال العام","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["مدخلات كيميائية","التصدير بالجملة","تكرير الملح","العمليات الصناعية"]},"de-icing-rock-salt":{"name":"ملح الطرق / إذابة الجليد","short":"ملح صخري خشن من سيوة لخفض درجة تجمد الماء على الطرق.","description":"ملح صخري خشن الحبيبات من منطقة سيوة، يُستخدم لخفض درجة تجمد الماء على الطرق السريعة ومدارج المطارات والبنية التحتية الحيوية. يتميز بحجم حبيبات وثبات محدد لضمان ذوبان سريع وموثوق للجليد حتى في ظل حركة مرور كثيفة.","keyFeatures":["حبيبات خشنة لتغطية سطحية طويلة الأمد","إذابة سريعة وموثوقة للجليد والثلج","مقاومة عالية لحركة المرور والاحتكاك","متوافق مع معدات النشر القياسية","متاح بالجملة وفي أكياس 1 طن","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["الطرق السريعة","مدارج المطارات","الجسور والكباري","الأرصفة الصناعية"]},"tablet-salt":{"name":"ملح الأقراص","short":"أقراص ملح مكرر بشكل وسادة لوحدات تليين ومعالجة المياه.","description":"ملح مكرر مضغوط على شكل أقراص صغيرة بيضاء بشكل وسادة أو أقراص دائرية. مصمم ليذوب بانتظام دون أن يتفتت، لمنع انسداد أو تكتل وحدات تليين المياه وأنظمة المعالجة.","keyFeatures":["ملح مكرر عالي النقاء (≥ 99.8%)","شكل أقراص منتظم — بلا غبار أو كسور","ذوبان منتظم ومتوقع","يمنع الانسداد والتكتل","يُعبأ في أكياس 10 و25 كجم","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["أنظمة تليين المياه","معالجة المياه الصناعية","الغلايات التجارية","الاستخدام السكني"]},"pool-salt":{"name":"ملح حمامات السباحة","short":"ملح عالي النقاء لأنظمة الكلور الملحي في المسابح.","description":"ملح حمامات السباحة هو كلوريد صوديوم عالي النقاء مصمم خصيصاً لأنظمة التعقيم بالكلور الملحي. يختلف عن الملح العادي بخلوّه التام من مضادات التكتل واليود وأي إضافات قد تترك بقعاً على سطح المسبح أو تتلف خلايا المولّد. يذوب بسرعة ويغذّي مولّد الكلور لإنتاج ماء معقّم ألطف على البشرة والعينين من الكلور التقليدي.","keyFeatures":["كلوريد صوديوم نقي ≥ 99.5٪ — بدون إضافات","خالٍ من اليود ومضادات التكتل والمواد الرابطة","ذوبان سريع وبدون بقايا","متوافق مع كافة مولّدات الكلور الملحي","لطيف على البشرة والعينين والشعر ومعدات المسبح","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["المسابح المنزلية","المسابح التجارية","الفنادق والمنتجعات","النوادي الرياضية"]},"water-softener-salt":{"name":"ملح معالجة المياه","short":"أقراص وحبيبات خشنة لإزالة الكالسيوم والمغنسيوم من المياه العسرة.","description":"ملح عالي النقاء يتوفر في هيئة أقراص أو حبيبات خشنة، مصمم لإزالة أيونات الكالسيوم والمغنسيوم من المياه العسرة. يُنشّط راتنجات التبادل الأيوني بكفاءة عالية ويطيل عمر الأجهزة والغلايات ودوائر المياه الصناعية.","keyFeatures":["يزيل عسر الكالسيوم والمغنسيوم","ذوبانية عالية ونسبة شوائب منخفضة","متاح على هيئة أقراص وحبيبات","يحمي الغلايات والأجهزة والأنابيب","أداء ثابت عبر دورات التنشيط","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["مليِّنات منزلية","مليِّنات تجارية","معالجة المياه الصناعية","التكييف والغلايات"]},"industrial-salt":{"name":"الملح الصناعي","short":"ملح صناعي واسع الاستخدام للمصانع الكيميائية والنسيج والدباغة.","description":"فئة واسعة من الملح الصناعي يُستخدم في المصانع الكيميائية وصباغة النسيج ودباغة الجلود والعديد من العمليات التصنيعية الأخرى. يُورَّد بما يتوافق مع المواصفات التقنية لكل استخدام.","keyFeatures":["نقاء وحجم حبيبات ثابت","رطوبة منخفضة تسهّل التداول","يلبي المواصفات الصناعية الشائعة","متاح بالجملة والأكياس والأكياس الكبيرة","تحاليل معملية عند الطلب","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["الصناعات الكيميائية","صباغة النسيج","دباغة الجلود","الصابون والمنظفات"]},"food-grade-salt":{"name":"الملح الغذائي","short":"ملح مكرر ومُيوَّد مطابق للمواصفة المصرية 273.","description":"ملح مكرر ومغسول بالكامل، مُدعَّم باليود وفقًا للمواصفة القياسية المصرية 273. خالٍ من المعادن الثقيلة والملوثات، وآمن للاستخدام الغذائي المباشر والتعبئة والتوزيع بالتجزئة.","keyFeatures":["مطابق للمواصفة المصرية 273","مُيوَّد بيودات البوتاسيوم","خالٍ من المعادن الثقيلة والملوثات","حبيبات ناعمة ومنتظمة بجودة غذائية","متاح بتعبئات بيع بالتجزئة وبالجملة","إنتاج معتمد بشهادة ISO 22000:2018 لسلامة الغذاء"],"applications":["مصانع الأغذية","ملح التعبئة والتجزئة","المطاعم والفنادق","الاستخدام المنزلي"]},"marine-salt":{"name":"الملح البحري","short":"ملح بحري شمسي غني بالمعادن الطبيعية.","description":"يُحصد من الملاحات الساحلية على البحر الأحمر، ويتميز الملح البحري بمحتواه الطبيعي من المعادن وببلوراته النظيفة. منتج متعدد الاستخدامات ومطلوب في الأسواق الصناعية والغذائية الفاخرة على حد سواء.","keyFeatures":["تبخير شمسي طبيعي","محتوى معدني طبيعي غني","بلورات نظيفة ولامعة","مناسب للاستخدام الصناعي والغذائي الفاخر","مغسول ومدرَّج في الموقع","إنتاج معتمد بشهادة ISO 9001:2015"],"applications":["علامات غذائية فاخرة","تجزئة جورميه","الاستخدام الصناعي","أسواق التصدير"]}}},"industries":{"hero":{"title":"القطاعات التي نخدمها","subtitle":"نوفر منتجات ملحية متخصصة لكل قطاع صناعي."},"items":{"road-deicing":{"title":"إزالة الجليد من الطرق","body":"حلول ملحية فعالة لإذابة الجليد على الطرق والمطارات والأماكن العامة."},"industrial":{"title":"الاستخدام الصناعي","body":"ملح بمواصفات تناسب الصناعات الكيميائية والنسيجية والمعدنية."},"food":{"title":"الاستخدام الغذائي","body":"ملح مكرر بجودة غذائية للمصانع والموزعين ومحلات التجزئة."},"pools":{"title":"المسابح","body":"ملح نقي لأنظمة الكلور الملحي في المسابح التجارية والسكنية."},"commercial":{"title":"التوريد التجاري العام","body":"حلول توريد مرنة بكميات متفاوتة للأسواق المحلية والتصدير."}}},"contact":{"hero":{"title":"تواصل معنا","subtitle":"فريقنا جاهز للرد على استفساراتك وتلبية احتياجات مشروعك."},"info":{"address":"رأس غارب، البحر الأحمر، جمهورية مصر العربية","phone":"الهاتف","whatsapp":"واتساب","email":"البريد الإلكتروني","hours":"ساعات العمل","hoursValue":"الأحد – الخميس: 9 صباحًا – 5 مساءً","openMap":"افتح في خرائط جوجل"},"form":{"title":"أرسل لنا استفسارك","name":"الاسم","email":"البريد الإلكتروني","phone":"رقم الهاتف","company":"الشركة","product":"المنتج المطلوب","message":"الرسالة","submit":"إرسال الاستفسار","selectProduct":"اختر منتجًا"},"status":{"sending":"جاري الإرسال…","okTitle":"تم استلام استفسارك","okBody":"شكرًا لك — سيرد عليك فريقنا خلال يوم عمل.","errors":{"missing_fields":"يرجى ملء جميع الحقول المطلوبة.","invalid_email":"يرجى إدخال بريد إلكتروني صحيح.","not_configured":"نموذج التواصل غير متصل بقاعدة البيانات بعد. يرجى مراسلتنا مباشرة.","db_error":"حدث خطأ غير متوقع. يرجى المحاولة مرة أخرى بعد قليل."}}},"faq":{"hero":{"title":"الأسئلة الشائعة","subtitle":"إجابات على أكثر الأسئلة تكرارًا حول منتجاتنا وخدماتنا."},"items":{"q1":{"q":"ما أنواع الملح التي توفرونها؟","a":"نوفر الملح الخام، وملح الطرق (إذابة الجليد)، وملح الأقراص، وملح معالجة المياه، والملح الصناعي، والملح الغذائي المُيوَّد، والملح البحري."},"q2":{"q":"هل توفرون كميات بالجملة؟","a":"نعم، نوفر كميات بالجملة مع خيارات تعبئة متعددة وطاقة إنتاجية كبيرة تلبي طلبات التصدير والتوريد المحلي."},"q3":{"q":"هل تناسب منتجاتكم الاستخدام الصناعي والغذائي؟","a":"نعم، نوفر منتجات مخصصة لكل قطاع وفق مواصفات معتمدة، ويمكن طلب بيانات المواصفات الفنية عند الطلب."},"q4":{"q":"ما نطاق التوريد والتسليم؟","a":"نخدم جميع المحافظات داخل مصر، كما نقوم بالتصدير إلى الأسواق الإقليمية والدولية عبر موانئ البحر الأحمر."},"q5":{"q":"كيف أحصل على عرض سعر؟","a":"يمكنك تعبئة نموذج الاتصال على الموقع أو التواصل معنا عبر الهاتف أو واتساب وسنرد خلال 24 ساعة عمل."}}},"footer":{"company":"الشركة","quickLinks":"روابط سريعة","products":"المنتجات","contact":"اتصل بنا","rights":"جميع الحقوق محفوظة","tagline":"مورد الملح الصناعي الموثوق من البحر الأحمر"}},"timeZone":"Africa/Cairo","children":["$L3","$L4","$L5"]}]]}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"o52reiqEAnlRRzDw73_Je"}

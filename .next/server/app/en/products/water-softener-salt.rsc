21:["$","$L22",null,{"formats":"$undefined","locale":"en","messages":{"meta":{"siteName":"Red Sea Salt","tagline":"Trusted industrial salt supplier since 2011","description":"Red Sea Salt — producer and supplier of industrial salt, de-icing salt, pool salt, refined salt and double-washed salt from Ras Gharib, Red Sea, Egypt."},"nav":{"home":"Home","about":"About","products":"Products","industries":"Industries","blog":"Blog","contact":"Contact","faq":"FAQs","requestQuote":"Request a Quote"},"common":{"learnMore":"Learn more","viewAll":"View all","viewDetails":"View details","contactUs":"Contact us","requestInfo":"Request info","since":"Since","readMore":"Read more","backToProducts":"Back to products"},"home":{"hero":{"eyebrow":"Est. 2011 · Egypt","title":"Pure Egyptian salt for global markets","subtitle":"Producer of industrial salt, food-grade salt, de-icing salt and Siwa salt since 2011. We ship from every major Egyptian port through our trusted partners.","ctaPrimary":"Explore products","ctaSecondary":"Contact us","trustedBy":"Serving sectors across the region","sectors":{"construction":"Construction","chemicals":"Chemicals","food":"Food-grade","pools":"Pools","export":"Export","infrastructure":"Infrastructure","textiles":"Textiles","logistics":"Logistics"},"locationLabel":"Origin","qualityAssured":"Quality assured","since":"Since","stats":{"years":"Years","products":"Products","quality":"Purity","support":"Support"}},"about":{"eyebrow":"About us","title":"Over a decade of proven experience","body":"Since 2011 we have produced premium industrial salt, food-grade salt, de-icing rock salt and Siwa salt across multiple Egyptian sites. We ship from every major Egyptian port through our trusted logistics partners — serving industrial, food and infrastructure buyers across the region.","cta":"Get to know us","shippingTitle":"Shipping across Egypt","shippingBody":"We're not limited to the Red Sea — our trusted partners handle loading and export from every major Egyptian port.","badgeLabel":"Est. 2011","badgeLocation":"Egypt"},"categories":{"eyebrow":"Our products","title":"A complete range of salt products","subtitle":"We serve every sector with products tailored to different technical specifications."},"whyUs":{"eyebrow":"Why us","title":"Why choose Red Sea Salt","items":{"experience":{"title":"Proven experience","body":"More than 14 years producing and supplying industrial salt."},"capacity":{"title":"High production capacity","body":"Able to fulfil large and recurring orders on schedule."},"quality":{"title":"Guaranteed quality","body":"Pure salt meeting industry specifications."},"reliability":{"title":"Reliable delivery","body":"On-time fulfilment with flexible packaging and shipping."}}},"industries":{"eyebrow":"Industries we serve","title":"Salt solutions for every sector","subtitle":"Products suited for infrastructure, industry, food, swimming pools and commercial supply."},"featured":{"eyebrow":"Featured","title":"Selected products","subtitle":"Take a look at our most requested products."},"cta":{"eyebrow":"Get in touch","title":"Need a quote or technical specs?","body":"Our team is ready to answer inquiries and share specifications, packaging and supply options.","button":"Request a quote","secondary":"Browse products"},"gallery":{"eyebrow":"Our world","title":"A visual","titleItalic":"journey","subtitle":"From the mineral-rich ponds of Ras Gharib to the ports that carry our product across the region.","captionEyebrow":"Visual","viewImage":"Open image","close":"Close","next":"Next image","prev":"Previous image","items":{"rawHarvest":"Raw salt harvest","marine":"Solar-evaporated marine salt","tablets":"Compressed salt tablets","rockSalt":"Coarse rock salt — export ready","foodGrade":"Food-grade refined salt","industrial":"Industrial-grade production"}},"testimonials":{"eyebrow":"What clients say","title":"Voices from","titleItalic":"the field","subtitle":"Real feedback from the buyers, contractors, and operators who source with us.","emptyTitle":"Be the first to share your experience","emptyBody":"Once we publish our first approved reviews, they'll appear here. Your voice could be first.","form":{"eyebrow":"Leave a review","title":"Share your experience","subtitle":"Reviews are moderated before appearing publicly.","rating":"Your rating","selectRating":"Select a rating","name":"Name","email":"Email","message":"Your review","disclaimer":"Your email will never be published — we use it only to verify reviews.","submit":"Submit review"},"status":{"sending":"Sending…","okTitle":"Thank you for your review","okBody":"Your feedback has been received and will be published after a quick moderation.","errors":{"missing_fields":"Please fill in all required fields.","invalid_email":"Please enter a valid email address.","invalid_rating":"Please select a rating from 1 to 5 stars.","not_configured":"Reviews aren't connected to the database yet. Please try again later.","db_error":"Something went wrong on our side. Please try again in a moment."}}}},"about":{"hero":{"title":"About us","subtitle":"A leading Egyptian salt producer based in Ras Gharib since 2011."},"story":{"title":"Our story","body":"Red Sea Salt was founded in 2011 with a clear vision: deliver high-grade salt that meets the needs of industry and infrastructure both locally and internationally. Over more than a decade we have expanded production lines, scaled the supply network and built long-term partnerships with major buyers in the region."},"mission":{"title":"Our mission","body":"To provide pure, spec-compliant salt products with consistent quality and reliable supply."},"vision":{"title":"Our vision","body":"To be the leading salt supplier in the region through quality, commitment and innovation."},"values":{"title":"Our values","items":["Quality","Reliability","Punctuality","Transparency","Customer service"]},"location":{"title":"Our location","body":"Ras Gharib, Red Sea Governorate, Egypt — a strategic location with easy sea and land access."},"founder":{"eyebrow":"Meet the founder","name":"Ragab Salem","role":"Founder of Red Sea Salt Works","tagline":"15 years of excellence — from Egypt's heart to the global market.","body":"As the founder of Red Sea Salt since 2011, I have dedicated my career to transforming Egypt's natural resources into world-class strategic products. With over 15 years of technical expertise in crystallization and chemical purity, we provide the ultimate partnership for businesses seeking premium Egyptian salt. Our mission is to bridge the gap between local production and international standards, ensuring seamless success in global markets.","imageAlt":"Ragab Salem, founder of Red Sea Salt Works"}},"products":{"listing":{"title":"Our products","subtitle":"A full range of industrial and food-grade salt products"},"detail":{"specifications":"Specifications","keyFeatures":"Key features","applications":"Applications","packaging":"Packaging","gallery":"Gallery","videoTour":"Video tour","analysis":"Chemical analysis","cta":"Request this product"},"specsLabels":{"purity":"Purity","moisture":"Moisture","granule":"Granule"},"items":{"raw-salt":{"name":"Raw Salt","short":"Natural solar and rock salt crystals in bulk for industrial use.","description":"Natural solar and rock salt crystals harvested from our Egyptian salt sites and exported in bulk for industrial use or as a base material for further refining. Retains its natural mineral profile and some moisture, making it an ideal feedstock for downstream processing.","keyFeatures":["Naturally harvested from Egyptian land","Rich in native minerals","Ideal feedstock for refining and chemical processes","Available in large, export-ready volumes","Consistent, traceable supply year-round","ISO 9001:2015 certified production"],"applications":["Chemical feedstock","Bulk export","Salt refining","Industrial processes"]},"de-icing-rock-salt":{"name":"De-icing Rock Salt","short":"Coarse Siwa rock salt that lowers the freezing point of water on roads.","description":"Coarse-graded rock salt from Siwa, used to lower the freezing point of water on highways, airport runways and critical infrastructure. Graded for specific durability and grain size to deliver fast, reliable ice melt even under heavy traffic.","keyFeatures":["Coarse grain for long-lasting surface coverage","Fast, reliable ice and snow melt","Durable under traffic and abrasion","Compatible with standard spreading equipment","Supplied in bulk and 1-ton big bags","ISO 9001:2015 certified production"],"applications":["Highways","Airport runways","Bridges and overpasses","Industrial yards"]},"tablet-salt":{"name":"Tablet Salt","short":"Refined pillow-shaped salt tablets for softening and treatment units.","description":"Refined salt compacted into small, white pillow-shaped or round tablets. Engineered to dissolve evenly without breaking apart, preventing clogging or bridging in water softening and treatment systems.","keyFeatures":["High-purity refined salt (≥ 99.8%)","Uniform tablet shape — no fines or dust","Even, predictable dissolution","Prevents bridging and clogging","Packaged in 10 kg and 25 kg bags","ISO 9001:2015 certified production"],"applications":["Water softening systems","Industrial water treatment","Commercial boilers","Residential use"]},"pool-salt":{"name":"Pool Salt","short":"High-purity salt for saltwater chlorination pool systems.","description":"Pool salt is pharmaceutical-grade sodium chloride designed specifically for saltwater chlorination systems. Unlike common salt, it contains no anti-caking agents, iodine, or additives that would stain pool surfaces or disrupt generator cells. It dissolves quickly and feeds the chlorine generator to produce a gentle, spa-like chlorinated water that is softer on skin and eyes than traditional chlorine.","keyFeatures":["≥ 99.5% pure sodium chloride — no additives","Free from iodine, anti-caking agents, and binders","Fast, residue-free dissolution","Compatible with all major saltwater chlorinators","Gentle on skin, eyes, hair, and pool equipment","ISO 9001:2015 certified production"],"applications":["Residential pools","Commercial pools","Hotels and resorts","Sports clubs"]},"water-softener-salt":{"name":"Water Softener Salt","short":"Tablets and coarse granules that remove calcium and magnesium from hard water.","description":"High-purity salt available as tablets or coarse granules, formulated to remove calcium and magnesium ions from hard water. Regenerates ion-exchange resins efficiently and extends the life of appliances, boilers and industrial water circuits.","keyFeatures":["Removes calcium and magnesium hardness","High solubility and low insolubles","Tablet and granular formats available","Protects boilers, appliances and pipes","Consistent performance across regeneration cycles","ISO 9001:2015 certified production"],"applications":["Home softeners","Commercial softeners","Industrial water treatment","HVAC and boilers"]},"industrial-salt":{"name":"Industrial Salt","short":"Broad-use industrial salt for chemical plants, textiles and tanning.","description":"A broad category of industrial-grade salt used in chemical plants, textile dyeing, leather tanning and many other manufacturing processes. Supplied to meet the technical specifications of each application.","keyFeatures":["Consistent granulation and purity","Low moisture for reliable handling","Meets common industrial specifications","Available in bulk, bags and big bags","Backed by on-demand lab analysis","ISO 9001:2015 certified production"],"applications":["Chemical industry","Textile dyeing","Leather tanning","Soap and detergents"]},"food-grade-salt":{"name":"Food Grade Salt","short":"Fully refined, iodized salt compliant with Egyptian Standard 273.","description":"Fully refined and washed salt, fortified with Iodine in accordance with Egyptian Standard 273. Free from heavy metals and contaminants, it is safe for direct food use, packaging and retail distribution.","keyFeatures":["Compliant with Egyptian Standard 273","Iodized (fortified with potassium iodate)","Free from heavy metals and contaminants","Fine, uniform food-grade granulation","Available in retail and bulk packaging","ISO 22000:2018 certified food-safety management"],"applications":["Food manufacturers","Packaged retail salt","Restaurants and hotels","Household use"]},"marine-salt":{"name":"Marine Salt / Sea Salt","short":"Solar-harvested sea salt with a rich natural mineral profile.","description":"Harvested from coastal salt works along the Red Sea, marine salt is prized for its natural mineral profile and clean crystal structure. A versatile product in demand across both industrial and premium food markets.","keyFeatures":["Naturally solar-evaporated","Rich natural mineral profile","Clean, bright crystal structure","Suitable for industrial and premium food use","Washed and graded on site","ISO 9001:2015 certified production"],"applications":["Premium food brands","Gourmet retail","Industrial use","Export markets"]}}},"industries":{"hero":{"title":"Industries we serve","subtitle":"Specialised salt products for every industrial sector."},"items":{"road-deicing":{"title":"Road de-icing","body":"Effective salt solutions for clearing ice from roads, airports and public spaces."},"industrial":{"title":"Industrial use","body":"Salt with specifications tailored to chemical, textile and metals industries."},"food":{"title":"Food use","body":"Food-grade refined salt for manufacturers, distributors and retail."},"pools":{"title":"Pools","body":"Pure salt for saltwater chlorination systems — commercial and residential."},"commercial":{"title":"General commercial supply","body":"Flexible supply in varying quantities for local markets and export."}}},"contact":{"hero":{"title":"Contact us","subtitle":"Our team is ready to answer your inquiries and support your project."},"info":{"address":"Ras Gharib, Red Sea Governorate, Egypt","phone":"Phone","whatsapp":"WhatsApp","email":"Email","hours":"Hours","hoursValue":"Sunday – Thursday: 9am – 5pm","openMap":"Open in Google Maps"},"form":{"title":"Send us an inquiry","name":"Name","email":"Email","phone":"Phone","company":"Company","product":"Product of interest","message":"Message","submit":"Send inquiry","selectProduct":"Select a product"},"status":{"sending":"Sending…","okTitle":"Inquiry received","okBody":"Thanks — our team will reply within one business day.","errors":{"missing_fields":"Please fill in all required fields.","invalid_email":"Please enter a valid email address.","not_configured":"The contact form isn't connected to the database yet. Please email us directly.","db_error":"Something went wrong on our side. Please try again in a moment."}}},"faq":{"hero":{"title":"Frequently asked questions","subtitle":"Answers to the most common questions about our products and services."},"items":{"q1":{"q":"What types of salt do you supply?","a":"We supply raw salt, de-icing rock salt, tablet salt, water softener salt, industrial salt, food-grade (iodized) salt and marine/sea salt."},"q2":{"q":"Do you offer bulk quantities?","a":"Yes — we supply bulk quantities with flexible packaging and production capacity suited to export and local supply."},"q3":{"q":"Are your products suitable for industrial and food use?","a":"Yes — we produce grade-specific products with technical specifications available on request."},"q4":{"q":"What is your delivery area?","a":"We serve all governorates within Egypt and export to regional and international markets via Red Sea ports."},"q5":{"q":"How do I request a quote?","a":"Fill in the contact form on our website or reach out by phone or WhatsApp — we reply within one business day."}}},"footer":{"company":"Company","quickLinks":"Quick links","products":"Products","contact":"Contact","rights":"All rights reserved","tagline":"Trusted industrial salt supplier from the Red Sea"}},"now":"$undefined","timeZone":"Africa/Cairo","children":["$L23","$L24","$L25"]}]

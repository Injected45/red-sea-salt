# Copy this file to .env.local and fill in the values.

# ------------------------------------------------------------
# Supabase (required for contact form + testimonials persistence)
# ------------------------------------------------------------
# From your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional — server-only service-role key used by server actions when
# set (preferred for writes, bypasses RLS). If omitted, inserts use the
# anon key and rely on the RLS insert policies in supabase/schema.sql.
# Never expose this key to the browser.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ------------------------------------------------------------
# Public site URL (used for metadata + canonical)
# ------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://redseasalt.example
